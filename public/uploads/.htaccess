Options -Indexes

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
</IfModule>

<FilesMatch "\.(php|php[0-9]?|phtml|phar|cgi|pl|py|sh|shtml)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Deny from all
    </IfModule>
</FilesMatch>

<IfModule mod_php.c>
    php_flag engine off
</IfModule>

<IfModule mod_mime.c>
    RemoveHandler .php .phtml .php3 .php4 .php5 .php7 .php8
    RemoveType .php .phtml .php3 .php4 .php5 .php7 .php8
</IfModule>
